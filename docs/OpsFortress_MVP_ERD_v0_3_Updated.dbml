  business_identifier varchar
  contact_given_name varchar
  contact_family_name varchar
  contact_role varchar
  contact_email varchar
  contact_phone varchar
  reporting_responsibility text
  pdf_recipient boolean [not null, default: false]
  effective_from date
  effective_to date
  active_status boolean [not null, default: true]
  metadata jsonb
  created_at timestamp
  updated_at timestamp
  deleted_at timestamp
}

Table asset_types {
  id uuid [pk, default: `gen_random_uuid()`]
  asset_type_code varchar
  name varchar [not null]
  asset_category varchar
  inspection_required boolean [not null, default: false]
  prestart_required boolean [not null, default: false]
  posttask_required boolean [not null, default: false]
  maintenance_trigger_required boolean [not null, default: false]
  evidence_required boolean [not null, default: false]
  active_status boolean [not null, default: true]
  metadata jsonb
  created_at timestamp
  updated_at timestamp
  deleted_at timestamp
}

Table assets {
  id uuid [pk, default: `gen_random_uuid()`]
  account_id uuid [not null]
  business_entity_id uuid [not null]
  asset_type_id uuid
  asset_code varchar
  asset_name varchar [not null]
  asset_category varchar
  make_model varchar
  serial_number varchar
  registration_number varchar
  asset_status varchar [not null, default: 'active']
  inspection_required boolean [not null, default: false]
  prestart_required boolean [not null, default: false]
  posttask_required boolean [not null, default: false]
  maintenance_trigger_required boolean [not null, default: false]
  evidence_required boolean [not null, default: false]
  metadata jsonb
  created_at timestamp
  updated_at timestamp
  deleted_at timestamp
}

Table workplace_asset_assignments {
  id uuid [pk, default: `gen_random_uuid()`]
  account_id uuid [not null]
  workplace_id uuid [not null]
  asset_id uuid [not null]
  assigned_from date
  assigned_to date
  is_primary boolean [not null, default: false]
  active_status boolean [not null, default: true]
  metadata jsonb
  created_at timestamp
  updated_at timestamp
  deleted_at timestamp
}

Table worker_task_session_assets {
  id uuid [pk, default: `gen_random_uuid()`]
  worker_task_session_id uuid [not null]
  asset_id uuid [not null]
  selected_by_user_id uuid
  selection_reason varchar
  selected_at timestamp
  metadata jsonb
  created_at timestamp
  updated_at timestamp
}

Table generated_documents {
  id uuid [pk, default: `gen_random_uuid()`]
  account_id uuid [not null]
  business_entity_id uuid
  workplace_id uuid
  task_id uuid
  swms_version_id uuid
  jurisdiction_regulatory_profile_id uuid
  document_type varchar [not null]
  document_title varchar
  version_label varchar
  generation_trigger varchar
  bundle_key varchar
  status varchar [not null, default: 'draft']
  disk varchar
  path varchar
  file_hash varchar
  file_hash_algorithm varchar [not null, default: 'sha256']
  generated_by_user_id uuid
  generated_at timestamp
  metadata jsonb
  created_at timestamp
  updated_at timestamp
  deleted_at timestamp
}

Table document_delivery_events {
  id uuid [pk, default: `gen_random_uuid()`]
  generated_document_id uuid [not null]
  workplace_external_party_id uuid
  recipient_user_id uuid
  recipient_name varchar
  recipient_email varchar
  recipient_type varchar
  delivery_channel varchar [not null, default: 'email']
  status varchar [not null, default: 'pending']
  sent_at timestamp
  delivered_at timestamp
  failed_at timestamp
  failure_message text
  metadata jsonb
  created_at timestamp
  updated_at timestamp
}

