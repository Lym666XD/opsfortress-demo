}

TableGroup "WHS Content / Menu P0" {
  industries
  occupations
  tasks
  task_occupation_access
  task_industry_access
  swms_versions
  swms_activity_steps
  prestart_questions
  workplace_task_settings
}

TableGroup "Importer / Intake P0" {
  import_batches
  import_source_files
  import_validation_results
}

TableGroup "Runtime / Evidence P0" {
  worker_task_sessions
  swms_step_events
  prestart_submissions
