TableGroup "Core Platform / Onboarding P0" {
  customer_accounts
  countries
  business_identifier_types
  business_entities
  account_businesses
  business_identifiers
  workplaces
  workplace_environments
  business_industries
  users
  user_business_access
  user_workplace_access
  user_occupations
